# Copy to .env and source it, or export manually before running the binary.
PORT=8080
GCP_PROJECT_ID=cars-api-local

# Point at the local emulator; unset this for real GCP Firestore.
FIRESTORE_EMULATOR_HOST=localhost:8081

# Rate limiting — requests per second and maximum burst per IP
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20

# In-memory cache TTL for individual car entries (seconds)
CACHE_TTL_SECONDS=300
