{
  "info": {
    "name": "cars-api",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "carId",
      "value": "",
      "type": "string"
    },
    {
      "key": "carIds",
      "value": "[]",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Liveness",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "Readiness",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/ready"
          }
        }
      ]
    },
    {
      "name": "Cars",
      "item": [
        {
          "name": "Create car",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) {",
                  "    var ids = JSON.parse(pm.collectionVariables.get('carIds') || '[]');",
                  "    ids.push(json.id);",
                  "    pm.collectionVariables.set('carIds', JSON.stringify(ids));",
                  "    pm.collectionVariables.set('carId', json.id);",
                  "    console.log('Created car #' + ids.length + ' id=' + json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/v1/cars",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"make\": \"Toyota\",\n  \"model\": \"Camry\",\n  \"year\": 2022,\n  \"color\": \"Silver\",\n  \"price\": 24999.99,\n  \"mileage\": 15000,\n  \"vin\": \"1HGBH41JXMN109186\",\n  \"status\": \"available\"\n}"
            }
          }
        },
        {
          "name": "List cars",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/cars?page_size=10",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "cars"],
              "query": [
                { "key": "page_size", "value": "10" },
                { "key": "page_token", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get car",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/cars/:id",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "cars", ":id"],
              "variable": [
                { "key": "id", "value": "", "description": "Paste the car ID here" }
              ]
            }
          }
        },
        {
          "name": "Update car",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var ids = JSON.parse(pm.collectionVariables.get('carIds') || '[]');",
                  "if (ids.length === 0) {",
                  "    throw new Error('carIds is empty — run Create car first.');",
                  "}",
                  "pm.collectionVariables.set('carId', ids[ids.length - 1]);",
                  "console.log('Updating car id=' + ids[ids.length - 1]);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/v1/cars/{{carId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 22499.99,\n  \"status\": \"pending\"\n}"
            }
          }
        },
        {
          "name": "Delete car",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/v1/cars/:id",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "cars", ":id"],
              "variable": [
                { "key": "id", "value": "", "description": "Paste the car ID here" }
              ]
            }
          }
        }
      ]
    }
  ]
}
